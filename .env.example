# ===== Required for private-fetch =====
# GitHub personal access token (classic or fine-grained)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Telegram bot =====
# Token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated numeric Telegram chat IDs allowed to use the bot (e.g. 123456789,987654321).
# Leave blank for the first run, send /start to the bot, copy the returned chat_id here, then restart.
TELEGRAM_ALLOWED_CHAT_IDS=

# Default chat provider for the Telegram bot: ollama, lmstudio, vllm, or llamacpp
TELEGRAM_PROVIDER=ollama

# Default chat model for the Telegram bot
TELEGRAM_MODEL=qwen3.5:9b

# Comma-separated list of allowed private doc hosts
# PRIVATE_DOCS_HOSTS=docs.example.com,internal.corp.com

# Bearer token for private documentation sites
# PRIVATE_DOCS_TOKEN=your-bearer-token-here

# ===== Proxy (for Telegram or external API access) =====
# HTTP/SOCKS5 proxy URL. Examples:
#   PROXY_URL=http://127.0.0.1:7890
#   PROXY_URL=socks5://127.0.0.1:1080
# PROXY_URL=

# ===== Optional overrides =====
# Obsidian vault root override for Windows-side promotion.
# Leave blank to use C:\Users\<you>\Documents\AutoResearchVault on Windows.
# WSL worker scripts keep their own /mnt/c/... fallback when VAULT_ROOT is unset.
# VAULT_ROOT=C:\Users\User\Documents\AutoResearchVault

# LM Studio API key (only if authentication is enabled)
# LMSTUDIO_API_KEY=

# Explicit Windows host IP (for WSL2 when localhost forwarding fails)
# WINDOWS_HOST_IP=

# Scrapling MCP port
# SCRAPLING_PORT=8010

# LM Studio local bridge port (inside WSL)
# LMSTUDIO_LOCAL_PORT=1234

# Skill memory retrieval defaults
# SKILL_MEMORY_EMBEDDING_PROVIDER=lmstudio
# SKILL_MEMORY_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
# SKILL_MEMORY_TTL_DAYS=28
# SKILL_MEMORY_VECTOR_BACKEND=sqlite-vec

# HTTP timeout for LLM synthesis calls (seconds)
# HTTP_TIMEOUT_SECONDS=900

# ===== llama.cpp provider (v3.18+) =====
# Base URL for llama-server (default: http://127.0.0.1:8080)
# LLAMACPP_BASE=http://127.0.0.1:8080

# Path to the GGUF model file for llama-server
# LLAMACPP_MODEL_PATH=

# Number of layers to offload to GPU (99 = all layers)
# LLAMACPP_GPU_LAYERS=99

# Context size for llama-server
# LLAMACPP_CTX_SIZE=8192

# Context size for LLM calls (used for max_tokens calculation)
# NUM_CTX=8192

# Enable debug logging (set to 1)
# AUTO_RESEARCH_DEBUG=0

# Fetch retry configuration
# FETCH_MAX_RETRIES=3
# FETCH_RETRY_DELAY=5

# Maximum source bundle size in bytes before truncation (for LLM synthesis)
# MAX_SOURCE_BYTES=102400

# Explicit service base URLs (override auto-discovery)
# WINDOWS_OLLAMA_BASE_URL=
# WINDOWS_LMSTUDIO_BASE_URL=
# OLLAMA_BASE=
# LMSTUDIO_BASE=
